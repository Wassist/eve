{
  "name": "@wassist/eve",
  "version": "0.1.1",
  "description": "Wassist channel for Vercel eve – drop WhatsApp into any eve agent",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "push": "cd ../../ && git subtree push --prefix=packages/eve git@github.com:Wassist/eve.git main",
    "publish": "npm publish --access public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wassist/eve.git"
  },
  "homepage": "https://github.com/wassist/eve#readme",
  "bugs": {
    "url": "https://github.com/wassist/eve/issues"
  },
  "keywords": [
    "eve",
    "vercel-eve",
    "wassist",
    "whatsapp",
    "whatsapp-api",
    "agent",
    "agents",
    "channel",
    "ai-agent",
    "chatbot"
  ],
  "author": "Wassist",
  "license": "MIT",
  "sideEffects": false,
  "dependencies": {
    "@wassist/sdk": "^0.1.2"
  },
  "peerDependencies": {
    "eve": ">=0.13.0"
  },
  "devDependencies": {
    "@types/node": "^22",
    "eve": ">=0.13.0",
    "tsup": "^8",
    "tsx": "^4",
    "typescript": "^5"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ]
}
